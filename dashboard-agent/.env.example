# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to version control

# Company SSO
SSO_USERNAME=<username>@domain.net
SSO_PASSWORD=<password>

# Tableau
TABLEAU_EMAIL=<email>

# Atlassian API token for JIRA access (generate from https://id.atlassian.com/manage-profile/security/api-tokens)
ATLASSIAN_EMAIL=<email>
ATLASSIAN_API_TOKEN=<api_token>

# CloudHealth
CLOUDHEALTH_EMAIL=<email>

# CloudZero
CLOUDZERO_EMAIL=<email>
